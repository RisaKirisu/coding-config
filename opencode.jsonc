{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{file:~/coding-config/.api-keys/context7}"
      },
      "enabled": true
    }
  },
  "skills": {
    "paths": [
      "~/coding-config/skills"
    ]
  },
  "provider": {
    "ruoli": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "RuoLi",
      "options": {
        "baseURL": "https://ruoli.dev/v1",
        "apiKey": "{file:~/coding-config/.api-keys/ruoli}"
      },
      "models": {
        "gpt-5.5": {
          "name": "GPT-5.5",
          "limit": {
            "context": 272000,
            "output": 128000
          },
          "variants": {
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "auto",
              "textVerbosity": "medium",
              "forceReasoning": true
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "auto",
              "textVerbosity": "medium",
              "forceReasoning": true
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium",
              "forceReasoning": true
            }
          }
        },
        "gpt-5.4": {
          "name": "GPT-5.4",
          "limit": {
            "context": 272000,
            "output": 128000
          },
          "variants": {
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "auto",
              "textVerbosity": "low",
              "forceReasoning": true
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "low",
              "forceReasoning": true
            }
          }
        }
      }
    }
  },
  "permission": {
    "bash": {
      "*": "ask",
      "printf *": "allow",
      "bc *": "allow",
      "git *": "allow",
      "git branch -D *": "ask",
      "git branch -d *": "ask",
      "git branch -m *": "ask",
      "git merge*": "ask",
      "git commit*": "ask",
      "git push*": "ask",
      "grep *": "allow",
      "ls *": "allow",
      "stat *": "allow",
      "cat *": "deny",
      "echo *": "deny",
      "rm -rf *": "deny",
      "rm -r -f *": "deny",
      "rm -f -r *": "deny",
      "cargo test *": "allow",
      "cargo fmt *": "allow",
      "cargo check *": "allow",
      "cargo clippy *": "allow"
    },
    "lsp": "allow",
    "remove_voice_input_record": "ask"
  },
  "agent": {
    "plan": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high",
      "prompt": "{file:~/coding-config/plan.txt}",
      "permission": {
        "lsp": "allow"
      }
    },
    "build": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high"
    },
    "general-qa": {
      "mode": "primary",
      "description": "Answer general question and perform conversation",
      "prompt": "{file:~/coding-config/general-qa.md}",
      "model": "openai/gpt-5.5",
      "permission": {
        "edit": {
          "*": "ask",
          "~/chat_agent_scratchpad/**": "allow"
        },
        "external_directory": {
          "*": "ask",
          "~/chat_agent_scratchpad/**": "allow"
        },
        "bash": {
          "uv run python *": "allow"
        }
      }
    },
    "explore": {
      "model": "ruoli/gpt-5.4",
      "reasoningEffort": "medium"
    },
    "scout": {
      "model": "ruoli/gpt-5.4",
      "reasoningEffort": "medium"
    },
    "general": {
      "model": "ruoli/gpt-5.4",
      "reasoningEffort": "medium"
    }
  },
  "small_model": "openrouter/openai/gpt-oss-120b:exacto",
  "plugin": [
    "@tarquinen/opencode-dcp@latest"
  ]
}