{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    [
      "opencode-auto-resume",
      {
        "chunkTimeoutMs": 60000,
        "gracePeriodMs": 5000,
        "maxRetries": 3
      }
    ]
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-aa5c831d-f70c-444c-a8a1-4ec996ffaea2"
      },
      "enabled": true
    }
  },
  "permission": {
    "bash": {
      "*": "ask",
      "printf *": "allow",
      "bc *": "allow",
      "git *": "allow",
      "git branch -D *": "ask",
      "git branch -d *": "ask",
      "git branch -m *": "ask",
      "git merge*": "ask",
      "git commit*": "ask",
      "git push*": "ask",
      "grep *": "allow",
      "ls *": "allow",
      "stat *": "allow",
      "cat *": "deny",
      "echo *": "deny",
      "rm -rf *": "deny",
      "rm -r -f *": "deny",
      "rm -f -r *": "deny"
    },
    "lsp": "allow",
    "remove_voice_input_record": "ask"
  },
  "agent": {
    "plan": {
      "model": "openai/gpt-5.5",
      "permission": {
        "lsp": "allow"
      }
    },
    "build": {
      "model": "openai/gpt-5.5"
    },
    "general-qa": {
      "mode": "primary",
      "description": "Answer general question and perform conversation",
      "prompt": "{file:~/coding-config/general-qa.md}",
      "model": "openai/gpt-5.5",
      "permission": {
        "edit": {
          "*": "ask",
          "~/chat_agent_scratchpad/**": "allow"
        },
        "external_directory": {
          "*": "ask",
          "~/chat_agent_scratchpad/**": "allow"
        },
        "bash": {
          "uv run python *": "allow"
        }
      }
    },
    "explore": {
      "model": "openai/gpt-5.4-mini",
      "reasoningEffort": "high"
    },
    "scout": {
      "model": "openai/gpt-5.4-mini",
      "reasoningEffort": "high"
    },
    "general": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "medium"
    }
  },
  "small_model": "openrouter/openai/gpt-oss-120b:exacto"
}